{
  "name": "@gitcanvas/desktop",
  "version": "0.1.0",
  "private": true,
  "productName": "GitCanvas",
  "type": "module",
  "description": "GitCanvas desktop Electron app.",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint src",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "dist": "electron-vite build && electron-builder --mac --config electron-builder.yml",
    "dist:dir": "electron-vite build && electron-builder --mac --dir --config electron-builder.yml"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.0",
    "better-sqlite3": "^12.0.0",
    "drizzle-orm": "^0.45.0",
    "electron-log": "^5.4.0",
    "fast-glob": "^3.3.0",
    "html-to-image": "^1.11.0",
    "ignore": "^7.0.0",
    "simple-git": "^3.35.0",
    "ulidx": "^2.4.0",
    "zod": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@gitcanvas/shared": "workspace:*",
    "@gitcanvas/tsconfig": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.0",
    "@tailwindcss/vite": "^4.2.0",
    "@tanstack/react-query": "^5.90.0",
    "@types/better-sqlite3": "^7.6.12",
    "lucide-react": "^1.8.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "clsx": "^2.1.0",
    "drizzle-kit": "^0.31.0",
    "electron": "^41.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.7.2",
    "vite": "^7.0.0"
  }
}
